#!/bin/bash
echo "🎤 Voice Mode Activated (speak clearly, Ctrl+C to exit)"

while true; do
    echo "Listening..."
    # Record 5 seconds of audio
    arecord -d 5 -f cd /tmp/command.wav 2>/dev/null
    # Convert speech to text (simple)
    echo "Processing..."
    text=$(whisper-cpp /tmp/command.wav 2>/dev/null | head -n 1)
    echo "You said: $text"
    
    if [[ "$text" == *"exit"* ]]; then
        echo "Voice mode closed."
        break
    fi
    
    # Get AI response
    response=$(ollama run kali-helper "$text" --format json | jq -r '.response')
    echo "KaliHelper: $response"
    
    # Speak response
    echo "$response" | espeak -v en-us -s 150
done
